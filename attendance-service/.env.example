# Laravel API
LARAVEL_API_URL=http://localhost:8000/api
LARAVEL_API_KEY=

# Server
PORT=4000
HOST=0.0.0.0

# ZKT Devices
ZKT_CONNECTION_TIMEOUT=5000
ZKT_RECONNECT_INTERVAL=30000
ZKT_HEARTBEAT_INTERVAL=60000

# Offline Cache
DB_PATH=./data/cache.sqlite

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/service.log

# WebSocket
WS_PORT=4001
